{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/persona-object-protocol/plugin_config.schema.json",
  "title": "POP Plugin Discovery Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "plugin_paths": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "package_name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "path"
            ]
          }
        ]
      }
    },
    "plugin_packages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "plugin_package_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
